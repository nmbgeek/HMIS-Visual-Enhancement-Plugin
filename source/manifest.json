{
  "name": "HMIS Visual Enhancement",
  "description": "Adds contrast to the Community Services HMIS UI and highlights missing data fields.",
  "version": "0.9",
  "manifest_version": 3,
  "author": "Clint Johnson",
  "browser_specific_settings": {
    "gecko": {
      "id": "hmis-visual-enhancement@clintjohnson",
      "strict_min_version": "143.0",
      "update_url": "https://raw.githubusercontent.com/nmbgeek/HMIS-Visual-Enhancement-Plugin/master/updates.json",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "64": "cs-64.png",
    "128": "cs-128.png",
    "256": "cs-256.png",
    "512": "cs-512.png"
  },
  "content_scripts": [
    {
      "css": ["cs-custom.css"],
      "matches": [
        "https://wscs.wellsky.com/*"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["cs-custom.css"],
      "matches": [
        "https://wscs.wellsky.com/*"
      ]
    }
  ]
}
